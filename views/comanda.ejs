<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comanda Mesa <%= pedido.mesa_numero %></title>
    <style>
        @media print {
            body {
                width: <%= Number(config.ancho_papel || 80) %>mm;
                margin: 0;
                padding: 6px;
                font-size: <%= Number(config.font_size || 1) === 2 ? '1.1em' : '1em' %>;
            }
            .no-print { display: none; }
        }
        body {
            font-family: Arial, sans-serif;
            max-width: <%= Number(config.ancho_papel || 80) %>mm;
            margin: 0 auto;
            padding: 8px;
        }
        .center { text-align: center; }
        .muted { color: #666; font-size: .85em; }
        .divider { border-top: 1px dashed #000; margin: 8px 0; }
        .linea { padding: 6px 0; border-bottom: 1px dotted #ddd; }
        .nota { font-size: .9em; color: #a40000; margin-top: 2px; }
    </style>
</head>
<body>
    <div class="no-print center" style="margin-bottom: 10px;">
        <button onclick="window.print()">Imprimir comanda</button>
        <button onclick="window.close()">Cerrar</button>
        <div class="muted" style="margin-top:6px;">
            Impresora sugerida: <strong><%= config.impresora_comandas || 'Predeterminada del sistema' %></strong>
        </div>
    </div>

    <div class="center">
        <strong><%= config.nombre_negocio || 'Comanda' %></strong>
    </div>
    <div class="muted center">
        <div>Mesa: <strong><%= pedido.mesa_numero %></strong></div>
        <div>Mesero: <strong><%= pedido.mesero_nombre || 'Sin asignar' %></strong></div>
        <div>Hora: <%= new Date().toLocaleString('es-CO') %></div>
    </div>

    <div class="divider"></div>
    <div><strong>COMANDA</strong></div>
    <div class="divider"></div>

    <% if (!items || items.length === 0) { %>
        <div class="muted">Sin ítems para imprimir.</div>
    <% } else { %>
        <% items.forEach(function(it){ %>
            <div class="linea">
                <div><strong>x<%= Number(it.cantidad || 0) %></strong> - <%= it.producto_nombre %></div>
                <% if (it.nota) { %>
                    <div class="nota">Obs: <%= it.nota %></div>
                <% } %>
            </div>
        <% }) %>
    <% } %>

    <div class="divider"></div>
    <div class="muted center">Pedido #<%= pedido.id %></div>

    <% if (typeof auto_print !== 'undefined' && auto_print) { %>
        <script>
            window.addEventListener('load', function(){
                try { window.print(); } catch (_) {}
            });
        </script>
    <% } %>
</body>
</html>
